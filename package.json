{
  "name": "serverless_ai_gateway",
  "version": "1.4.4",
  "scripts": {
    "frontend:build": "cd frontend && npm run build",
    "frontend:build:dev": "cd frontend && npm run build -- --mode development",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:dev:dev": "cd frontend && npm run dev -- --mode development",
    "backend:dev": "wrangler dev",
    "backend:dev:local": "npx tsx watch src/local.ts",
    "backend:start": "npx tsx src/local.ts",
    "backend:start:integrated": "npm run frontend:build && npx tsx src/local.ts",
    "backend:test": "TEST_MODE=node vitest --run --config vitest.config.ts",
    "backend:test:real": "TEST_MODE=node TEST_REAL_API=true vitest --run --config vitest.config.ts",
    "backend:test:watch": "vitest --watch",
    "backend:test:coverage": "vitest --run --coverage",
    "backend:test:api": "vitest --run tests/api",
    "backend:test:integration": "vitest --run tests/integration",
    "backend:test:ai": "vitest --run tests/api/ai",
    "backend:test:node": "TEST_MODE=node vitest --run --config vitest.config.ts",
    "backend:test:worker": "TEST_MODE=worker vitest --run --config vitest.worker.config.ts",
    "backend:test:all": "npm run backend:test:node && npm run backend:test:worker",
    "predeploy": "npm run frontend:build",
    "deploy": "wrangler deploy --minify",
    "db:init:local": "npx tsx script/db.ts init --env local",
    "db:migrate:local": "npx tsx script/db.ts migrate --env local",
    "db:clear:local": "npx tsx script/db.ts clear --env local",
    "db:status:local": "npx tsx script/db.ts status --env local",
    "db:migrate:worker-local": "npx tsx script/db.ts migrate --env worker-local",
    "db:clear:worker-local": "npx tsx script/db.ts clear --env worker-local",
    "db:status:worker-local": "npx tsx script/db.ts status --env worker-local",
    "db:migrate:worker-cloud": "npx tsx script/db.ts migrate --env worker-cloud",
    "db:clear:worker-cloud": "npx tsx script/db.ts clear --env worker-cloud",
    "db:status:worker-cloud": "npx tsx script/db.ts status --env worker-cloud"
  },
  "dependencies": {
    "@fortaine/fetch-event-source": "^3.0.6",
    "@hono/node-server": "^1.19.9",
    "@types/node": "^24.0.13",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "hono": "^4.12.3",
    "knex-cloudflare-d1": "^0.1.1",
    "sutando": "^1.7.2",
    "tsx": "^4.20.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250712.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dotenv": "^6.1.1",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "sqlite3": "^5.1.7",
    "ts-prune": "^0.10.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
