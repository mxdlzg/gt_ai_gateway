{
    "productName": "GT AI Gateway",
    "version": "1.5.3",
    "identifier": "com.gtcoder.aigateway",
    "build": {
        "frontendDist": "../../frontend/dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "cd ../frontend && npm run dev",
        "beforeBuildCommand": "cd ../frontend && npm run build:tauri"
    },
    "app": {
        "windows": [
            {
                "title": "GT AI Gateway",
                "label": "splashscreen",
                "url": "splash.html",
                "width": 500,
                "height": 340,
                "decorations": false,
                "transparent": true,
                "center": true,
                "resizable": false,
                "alwaysOnTop": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": {
            "../../resource/migrate/*": "resource/migrate/"
        },
        "externalBin": [
            "../build/binaries/ai-gateway-backend"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
